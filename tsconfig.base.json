{
	"extends": "@tsconfig/node22/tsconfig.json",
	"include": ["src/**/*"],
	"compilerOptions": {
		"module": "Node20",
		"moduleResolution": "Node16",
		"importHelpers": false,
		"noEmitOnError": false,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true
	}
}
